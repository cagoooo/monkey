# =============================================
# 🔑 環境變數範本（.env.example）
# =============================================
# 複製此檔為 .env，填入真實值後即可在本地開發
# 所有值同時需設定到 GitHub Repository Secrets
# =============================================

# --- Gemini AI ---
GEMINI_API_KEY="你的_Gemini_API_Key"

# --- Firebase 設定（排行榜功能必要） ---
VITE_FIREBASE_API_KEY="你的_Firebase_Web_API_Key"
VITE_FIREBASE_AUTH_DOMAIN="你的專案.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="你的_Firebase_Project_ID"
VITE_FIREBASE_STORAGE_BUCKET="你的專案.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="你的_Sender_ID"
VITE_FIREBASE_APP_ID="1:你的_Sender_ID:web:你的_App_ID"
VITE_FIREBASE_DATABASE_ID="你的_Firestore_Database_ID（非預設名稱時才需要）"
